IB_HOST=127.0.0.1
IB_PORT=7497 #4002 for VM
IB_CLIENT_ID=9

BRIDGE_TOKEN=token

ENABLE_TRADING=true

AZURE_RESEARCHER_URL=https://<proj>.services.ai.azure.com/api/projects/proj-default/applications/<reasearcher_name>/protocols/openai
AZURE_TRADER_URL=https://<proj>.services.ai.azure.com/api/projects/proj-default/applications/</protocols/openai
AZURE_API_VERSION=2025-11-15-preview

# --- Account/base currency the bridge assumes for "cash-only" checks & display ---
DEFAULT_CURRENCY=USD

# --- Contract routing defaults (US equities via SMART) ---
DEFAULT_EXCHANGE=SMART
DEFAULT_PRIMARY_EXCHANGE=NASDAQ

# --- Optional: tune snapshot/quote timeouts (seconds) ---
SNAPSHOT_WAIT_SECS=2.0
QUOTE_WAIT_SECS=5
MARKET_DATA_TYPE=1